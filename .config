# 自动生成文件；请勿手动编辑。
# ImmortalWrt 编译配置
CONFIG_MODULES=y						# 启用内核模块支持
CONFIG_HAVE_DOT_CONFIG=y				# 标识当前存在有效的.config编译配置文件
CONFIG_HOST_OS_LINUX=y					# 编译主机操作系统为Linux
CONFIG_TARGET_airoha=y					# 目标芯片平台：airoha（翱锐）
CONFIG_TARGET_airoha_an7581=y			# 子平台：an7581
CONFIG_TARGET_airoha_an7581_DEVICE_bell_xg-040g-md=y	# 编译目标设备：bell_xg-040g-md
CONFIG_HAS_SUBTARGETS=y				# 平台包含细分子平台
CONFIG_HAS_DEVICES=y					# 平台包含多个硬件设备型号
CONFIG_TARGET_BOARD="airoha"			# 主板平台名称
CONFIG_TARGET_SUBTARGET="an7581"		# 子平台名称
CONFIG_TARGET_PROFILE="DEVICE_bell_xg-040g-md"	# 设备配置方案名称
CONFIG_TARGET_ARCH_PACKAGES="aarch64_cortex-a53"	# 架构包路径：AArch64 Cortex-A53
CONFIG_DEFAULT_TARGET_OPTIMIZATION="-Os -pipe -mcpu=cortex-a53"	# 目标设备默认编译优化参数
CONFIG_CPU_TYPE="cortex-a53"			# CPU型号：Cortex-A53 64位四核
CONFIG_LINUX_6_12=y					# 使用Linux 6.12内核版本
CONFIG_DEFAULT_airoha-en7581-npu-firmware=y	# 默认预装airoha en7581 NPU固件
CONFIG_DEFAULT_base-files=y				# 默认预装系统基础文件包
CONFIG_DEFAULT_blkid=y					# 默认预装磁盘UUID识别工具blkid
CONFIG_DEFAULT_ca-bundle=y				# 默认预装根证书合集
CONFIG_DEFAULT_dnsmasq-full=y			# 默认完整版dnsmasq DNS/DHCP服务
CONFIG_DEFAULT_dropbear=y				# 默认预装Dropbear轻量SSH服务端
CONFIG_DEFAULT_firewall4=y				# 默认预装nftables防火墙fw4
CONFIG_DEFAULT_fstools=y				# 默认预装文件系统工具集
CONFIG_DEFAULT_kmod-gpio-button-hotplug=y	# 默认GPIO按键热插拔内核模块
CONFIG_DEFAULT_kmod-i2c-an7581=y		# 默认an7581平台I2C总线内核模块
CONFIG_DEFAULT_kmod-leds-gpio=y			# 默认GPIO控制LED内核模块
CONFIG_DEFAULT_kmod-nft-offload=y		# 默认nftables硬件加速卸载模块
CONFIG_DEFAULT_kmod-phy-airoha-en8811h=y	# 默认airoha en8811h以太网PHY驱动
CONFIG_DEFAULT_kmod-usb-storage-uas=y	# 默认USB UAS高速存储驱动模块
CONFIG_DEFAULT_libc=y					# 默认C标准库musl
CONFIG_DEFAULT_libgcc=y				# 默认GCC运行库
CONFIG_DEFAULT_libustream-openssl=y		# 默认基于OpenSSL的ustream网络库
CONFIG_DEFAULT_logd=y					# 默认系统日志守护进程logd
CONFIG_DEFAULT_lsblk=y					# 默认块设备查看工具lsblk
CONFIG_DEFAULT_mtd=y					# 默认闪存MTD分区操作工具
CONFIG_DEFAULT_netifd=y				# 默认网络接口管理守护进程netifd
CONFIG_DEFAULT_nftables=y				# 默认nftables网络过滤框架
CONFIG_DEFAULT_odhcp6c=y				# 默认IPv6 DHCP客户端
CONFIG_DEFAULT_odhcpd-ipv6only=y		# 默认仅IPv6的DHCP服务端
CONFIG_DEFAULT_ppp=y					# 默认PPP拨号协议支持
CONFIG_DEFAULT_ppp-mod-pppoe=y			# 默认PPPoE拨号模块
CONFIG_DEFAULT_procd-ujail=y			# 默认进程沙箱隔离ujail
CONFIG_DEFAULT_ubi-utils=y				# 默认UBI闪存分区工具
CONFIG_DEFAULT_uboot-envtools=y			# 默认U-Boot环境变量读写工具
CONFIG_DEFAULT_uci=y					# 默认OpenWrt统一配置工具UCI
CONFIG_DEFAULT_uclient-fetch=y			# 默认轻量HTTP下载工具uclient-fetch
CONFIG_DEFAULT_urandom-seed=y			# 默认系统随机种子文件
CONFIG_DEFAULT_urngd=y					# 默认安全随机数生成服务
CONFIG_AUDIO_SUPPORT=y					# 启用音频硬件支持
CONFIG_GPIO_SUPPORT=y					# 启用GPIO通用引脚支持
CONFIG_PCI_SUPPORT=y					# 启用PCI总线支持
CONFIG_PCIE_SUPPORT=y					# 启用PCI-E高速总线支持
CONFIG_PINCTRL_SUPPORT=y				# 启用引脚复用控制
CONFIG_PWM_SUPPORT=y					# 启用PWM脉冲宽度调制
CONFIG_USB_SUPPORT=y					# 启用USB总线硬件支持
CONFIG_USES_PM=y						# 启用电源管理框架
CONFIG_USES_DEVICETREE=y				# 启用设备树硬件描述
CONFIG_USES_INITRAMFS=y				# 启用内存临时根文件系统initramfs
CONFIG_USES_SQUASHFS=y					# 启用SquashFS只读压缩文件系统
CONFIG_NAND_SUPPORT=y					# 启用NAND闪存支持
CONFIG_ARCH_64BIT=y					# 64位系统架构
CONFIG_REGULATOR_SUPPORT=y				# 启用电压稳压调节器驱动
CONFIG_aarch64=y						# 架构为AArch64 ARM64
CONFIG_ARCH="aarch64"					# 系统架构名称
#
CONFIG_DEFAULT_airoha-en7581-npu-firmware=y	# 默认预装airoha en7581 NPU固件
CONFIG_PACKAGE_airoha-en7581-npu-firmware=y	#启用 Airoha EN7581 NPU (神经网络处理单元) 的固件	
CONFIG_PACKAGE_luci-app-airoha-npu=y		#启用 Luci 界面下的 Airoha NPU 管理应用程序
CONFIG_PACKAGE_kmod-macvlan=y				#启用macvlan 功能的核心驱动
# ========================== 温度传感器 ==========================
CONFIG_PACKAGE_kmod-thermal-an7581=y                 # MT7621 系列芯片专用温度传感器驱动（用于读取 CPU 温度）
CONFIG_PACKAGE_kmod-hwmon-core=y                 # 硬件监控核心模块（所有温度/电压传感器依赖的基础库）
# ====================== USB 核心支持 ======================
CONFIG_USB_SUPPORT=y                               # USB 总开关
#CONFIG_PACKAGE_kmod-usb-xhci-hcd=y                 # XHCI 主控制器驱动（USB 3.0 标准）
CONFIG_PACKAGE_kmod-usb-xhci-mtk=y                 # MTK USB3 主控驱动
CONFIG_PACKAGE_kmod-usb-core=y                     # USB 核心基础驱动
CONFIG_PACKAGE_kmod-usb2=y                         # USB 2.0 支持
CONFIG_PACKAGE_kmod-usb3=y                         # USB 3.0 支持
CONFIG_PACKAGE_kmod-usb-storage=y                  # U盘/移动硬盘支持
CONFIG_PACKAGE_kmod-usb-storage-uas=y              # USB 高速 UAS 协议
CONFIG_PACKAGE_block-mount=y                       # 块设备自动挂载工具

# ====================== Samba4 网络共享支持 ======================
CONFIG_PACKAGE_samba4-server=y                     # Samba4 服务端：实现局域网文件/打印机共享核心服务
CONFIG_PACKAGE_luci-app-samba4=y                   # Samba4 Web 插件：LuCI 界面可视化配置共享目录/权限
CONFIG_PACKAGE_autosamba=y                         # 自动共享工具：插入 USB 设备后自动挂载并创建 Samba 共享
CONFIG_PACKAGE_luci-i18n-samba4-zh-cn=y            # Samba4 中文语言包：Web 界面显示中文，便于操作

# ============= 文件系统支持 =================
CONFIG_PACKAGE_kmod-fs-ext4=y                      # EXT4 格式支持
CONFIG_PACKAGE_kmod-fuse=y                         # FUSE 虚拟文件系统
CONFIG_PACKAGE_ntfs-3g=y                           # NTFS 完整读写
CONFIG_PACKAGE_kmod-nls-utf8=y                     # UTF-8 中文编码
CONFIG_PACKAGE_kmod-lib-crc16=y                    # CRC16 底层依赖库

# ======================= 系统基础 =======================
CONFIG_PACKAGE_kmod-reboot=y                       # 内核重启修复

# ======================== 防火墙（无重复纯净版） ========================
CONFIG_PACKAGE_kmod-ipt-core=y                     # iptables 核心模块
CONFIG_PACKAGE_kmod-ipt-conntrack=y                # 连接跟踪
CONFIG_PACKAGE_kmod-ipt-nat=y                      # NAT 转发（上网必备）
CONFIG_PACKAGE_kmod-nft-compat=y                   # iptables/nftables 兼容层
CONFIG_PACKAGE_iptables-nft=y                      # iptables 新后端
CONFIG_PACKAGE_xtables-legacy=y                    # 传统 iptables 命令兼容
CONFIG_PACKAGE_xtables-nft=y                       # nftables 新一代命令工具

# ======================== 全锥 NAT（纯净无重复） ========================
CONFIG_PACKAGE_kmod-ipt-fullconenat=y              # 全锥 NAT 内核模块
CONFIG_PACKAGE_iptables-mod-fullconenat=y          # 全锥 NAT 工具
CONFIG_PACKAGE_luci-app-fullconenat=y              # 全锥 NAT 网页设置


#
#
# 目标镜像相关配置
#
CONFIG_TARGET_ROOTFS_INITRAMFS=y		# 生成initramfs内存根文件系统镜像
CONFIG_TARGET_INITRAMFS_COMPRESSION_NONE=y	# initramfs不做额外压缩
CONFIG_EXTERNAL_CPIO=""					# 外部CPIO镜像文件路径（空）
#
# 根文件系统归档包
#
#
# 根文件系统镜像配置
#
CONFIG_TARGET_ROOTFS_SQUASHFS=y			# 根文件系统使用SquashFS格式
CONFIG_TARGET_SQUASHFS_BLOCK_SIZE=256	# SquashFS分块大小256KB
CONFIG_TARGET_SQUASHFS_BLOCK_READERS=4	# SquashFS并行读块线程数4
CONFIG_TARGET_SQUASHFS_SMALL_READERS=4	# SquashFS小文件读取线程4
CONFIG_TARGET_UBIFS_FREE_SPACE_FIXUP=y	# 修复UBIFS空闲空间计算
CONFIG_TARGET_UBIFS_JOURNAL_SIZE=""		# UBIFS日志分区大小（默认自动）
#
