CONFIG_BUSYBOX_CONFIG_GREP=y				# grep正则匹配文本
CONFIG_BUSYBOX_CONFIG_EGREP=y				# egrep扩展正则grep
CONFIG_BUSYBOX_CONFIG_FGREP=y				# fgrep固定字符串精确匹配
CONFIG_BUSYBOX_CONFIG_FEATURE_GREP_CONTEXT=y	# grep显示匹配上下文行
CONFIG_BUSYBOX_CONFIG_XARGS=y				# xargs批量处理文件参数
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_CONFIRMATION=y	# xargs执行前确认
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_QUOTES=y	# xargs支持带引号文件名
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_TERMOPT=y	# xargs终端参数兼容
CONFIG_BUSYBOX_CONFIG_FEATURE_XARGS_SUPPORT_ZERO_TERM=y	# xargs空分隔符安全处理文件名
# 文件查找工具结束
#
# 系统启停工具
#
CONFIG_BUSYBOX_CONFIG_HALT=y				# halt关机
CONFIG_BUSYBOX_CONFIG_POWEROFF=y			# poweroff断电关机
CONFIG_BUSYBOX_CONFIG_REBOOT=y			# reboot重启设备
# 系统启停工具结束
#
# 用户密码管理工具
#
CONFIG_BUSYBOX_CONFIG_FEATURE_SHADOWPASSWDS=y	# 影子密码兼容
CONFIG_BUSYBOX_CONFIG_FEATURE_DEFAULT_PASSWD_ALGO="sha256"	# 默认密码加密SHA256
CONFIG_BUSYBOX_CONFIG_LOGIN=y				# login终端登录
CONFIG_BUSYBOX_CONFIG_PASSWD=y			# passwd修改密码
CONFIG_BUSYBOX_CONFIG_FEATURE_PASSWD_WEAK_CHECK=y	# 弱密码检测
# 用户密码管理工具结束
# Ext2文件系统工具
#
# Ext2文件系统工具结束
#
# 内核模块工具
#
# 内核模块工具结束
#
# Linux系统工具
#
CONFIG_BUSYBOX_CONFIG_DMESG=y			# dmesg查看内核日志
CONFIG_BUSYBOX_CONFIG_FEATURE_DMESG_PRETTY=y	# dmesg格式化彩色输出
CONFIG_BUSYBOX_CONFIG_FLOCK=y			# flock文件锁
CONFIG_BUSYBOX_CONFIG_HEXDUMP=y			# hexdump十六进制查看
CONFIG_BUSYBOX_CONFIG_HWCLOCK=y			# hwclock读写硬件时钟
CONFIG_BUSYBOX_CONFIG_MKSWAP=y			# mkswap创建交换分区
CONFIG_BUSYBOX_CONFIG_MOUNT=y			# mount挂载文件系统
CONFIG_BUSYBOX_CONFIG_FEATURE_MOUNT_HELPERS=y	# mount自动识别文件系统
CONFIG_BUSYBOX_CONFIG_FEATURE_MOUNT_CIFS=y	# mount挂载SMB共享
CONFIG_BUSYBOX_CONFIG_FEATURE_MOUNT_FLAGS=y	# mount丰富挂载参数
CONFIG_BUSYBOX_CONFIG_FEATURE_MOUNT_FSTAB=y	# mount读取/etc/fstab开机挂载
CONFIG_BUSYBOX_CONFIG_PIVOT_ROOT=y		# pivot_root切换根目录
CONFIG_BUSYBOX_CONFIG_SETSID=y			# setsid创建独立会话
CONFIG_BUSYBOX_CONFIG_SWAPON=y			# swapon启用交换分区
CONFIG_BUSYBOX_CONFIG_FEATURE_SWAPON_DISCARD=y	# swap支持SSD TRIM
CONFIG_BUSYBOX_CONFIG_FEATURE_SWAPON_PRI=y	# swap分区优先级
CONFIG_BUSYBOX_CONFIG_SWAPOFF=y			# swapoff关闭交换分区
CONFIG_BUSYBOX_CONFIG_SWITCH_ROOT=y		# switch_root切换临时根
CONFIG_BUSYBOX_CONFIG_TASKSET=y			# taskset绑定CPU核心
CONFIG_BUSYBOX_CONFIG_FEATURE_TASKSET_FANCY=y	# taskset完整CPU列表参数
CONFIG_BUSYBOX_CONFIG_FEATURE_TASKSET_CPULIST=y	# taskset显示CPU掩码
CONFIG_BUSYBOX_CONFIG_UMOUNT=y			# umount卸载文件系统
CONFIG_BUSYBOX_CONFIG_FEATURE_UMOUNT_ALL=y	# umount -a卸载全部挂载
CONFIG_BUSYBOX_CONFIG_FEATURE_MOUNT_LOOP=y	# mount支持loop虚拟磁盘
# Linux系统工具结束
#
# 杂项工具
#
CONFIG_BUSYBOX_CONFIG_CROND=y			# crond定时任务
CONFIG_BUSYBOX_CONFIG_FEATURE_CROND_SPECIAL_TIMES=y	# crond特殊定时@daily
CONFIG_BUSYBOX_CONFIG_FEATURE_CROND_DIR="/etc"	# crontab任务目录/etc
CONFIG_BUSYBOX_CONFIG_CRONTAB=y			# crontab编辑定时任务
CONFIG_BUSYBOX_CONFIG_DEVMEM=y			# /dev/mem物理内存访问
CONFIG_BUSYBOX_CONFIG_LESS=y			# less分页查看文件
CONFIG_BUSYBOX_CONFIG_FEATURE_LESS_MAXLINES=9999999	# less无行数限制
CONFIG_BUSYBOX_CONFIG_LOCK=y				# 文件互斥
